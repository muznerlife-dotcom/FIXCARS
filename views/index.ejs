<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= stationName %> - Professional Auto Repair Services">
  <title><%= stationName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="container">
      <div class="nav-brand">
        <h2><%= stationName %></h2>
      </div>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-menu" id="primary-navigation">
        <li><a href="#home" class="nav-link">Home</a></li>
        <li><a href="#about" class="nav-link">About</a></li>
        <li><a href="#services" class="nav-link">Services</a></li>
        <li><a href="#gallery" class="nav-link">Gallery</a></li>
        <li><a href="#contact" class="nav-link">Contact</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="home" class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1><%= stationName %></h1>
      <p class="hero-tagline"><%= tagline %></p>
      <div class="hero-buttons">
        <a href="#contact" class="btn btn-primary">Get in Touch</a>
        <a href="#services" class="btn btn-secondary">Our Services</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="container">
      <div class="section-header">
        <h2>About Us</h2>
        <div class="section-underline"></div>
      </div>
      <div class="about-content">
        <div class="about-text">
          <h3>Your Trusted Auto Care Partner</h3>
          <p>
            With over 15 years of experience in automotive repair and maintenance, we pride ourselves on 
            delivering exceptional service to every customer. Our team of certified mechanics is dedicated 
            to keeping your vehicle running smoothly and safely.
          </p>
          <p>
            We understand that your vehicle is an important investment, and we treat it with the care and 
            respect it deserves. From routine maintenance to complex repairs, we have the expertise and 
            equipment to handle all your automotive needs.
          </p>
          <div class="about-features">
            <div class="feature">
              <div class="feature-icon">✓</div>
              <div class="feature-text">Certified Mechanics</div>
            </div>
            <div class="feature">
              <div class="feature-icon">✓</div>
              <div class="feature-text">Quality Parts</div>
            </div>
            <div class="feature">
              <div class="feature-icon">✓</div>
              <div class="feature-text">Fair Pricing</div>
            </div>
            <div class="feature">
              <div class="feature-icon">✓</div>
              <div class="feature-text">Fast Service</div>
            </div>
          </div>
        </div>
        <div class="about-image">
          <img src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=800&h=600&fit=crop" alt="Mechanic at work">
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="services">
    <div class="container">
      <div class="section-header">
        <h2>Our Services</h2>
        <div class="section-underline"></div>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🔧</div>
          <h3>Engine Repair</h3>
          <p>Complete engine diagnostics, repair, and rebuilding services for all makes and models.</p>
        </div>
        <div class="service-card">
          <div class="service-icon service-icon-image-wrapper">
            <img class="service-icon-image" src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=200&h=200&fit=crop" alt="Suspension repair">
          </div>
          <h3>Suspension Repair</h3>
          <p>Replacing worn shocks, struts, ball joints, and control arms to ensure a smooth and safe ride.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🛢️</div>
          <h3>Oil Changes</h3>
          <p>Quick and professional oil changes using high-quality oils and filters.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🔩</div>
          <h3>Brake Service</h3>
          <p>Comprehensive brake inspection, repair, and replacement for your safety.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">⚡</div>
          <h3>Electrical Systems</h3>
          <p>Expert diagnosis and repair of all electrical and electronic systems.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🔍</div>
          <h3>Diagnostics</h3>
          <p>Advanced computer diagnostics to identify and resolve any vehicle issues.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="gallery">
    <div class="container">
      <div class="section-header">
        <h2>Gallery</h2>
        <div class="section-underline"></div>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1625047509248-ec889cbff17f?q=80&w=2064&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Auto repair shop">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1625047509168-a7026f36de04?w=800&h=600&fit=crop" alt="Mechanic working">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1487754180451-c456f719a1fc?w=800&h=600&fit=crop" alt="Car engine">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=800&h=600&fit=crop" alt="Tools and equipment">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1530046339160-ce3e530c7d2f?w=800&h=600&fit=crop" alt="Car maintenance">
        </div>
        <div class="gallery-item">
          <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?w=800&h=600&fit=crop" alt="Classic car">
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
      <div class="section-header">
        <h2>Contact Us</h2>
        <div class="section-underline"></div>
      </div>
      <div class="contact-content">
        <div class="contact-info">
          <div class="contact-item">
            <div class="contact-icon">📞</div>
            <div class="contact-details">
              <h3>Phone</h3>
              <a href="tel:<%= phone.replace(/\s/g, '') %>"><%= phone %></a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">✉️</div>
            <div class="contact-details">
              <h3>Email</h3>
              <a href="mailto:<%= email %>"><%= email %></a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div class="contact-details">
              <h3>Address</h3>
              <a href="<%= googleMapsLink %>" target="_blank" rel="noopener noreferrer" class="address-link">
                <%= address %>
              </a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">🕒</div>
            <div class="contact-details">
              <h3>Hours</h3>
              <p><%= hours.weekdays %></p>
              <p><%= hours.saturday %></p>
              <p><%= hours.sunday %></p>
            </div>
          </div>
        </div>
        <div class="contact-map">
<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1152.1325510888612!2d-105.01238593455955!3d39.632157980453975!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876c8110ef421395%3A0xde6c2272142bc9f8!2sFamous%20Auto%20Repair!5e0!3m2!1sen!2sus!4v1779572794910!5m2!1sen!2sus" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-text">
          <p>&copy; 2026 <%= stationName %>. All rights reserved.</p>
          <p>Built with care for your automotive needs</p>
  
        </div>

      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
